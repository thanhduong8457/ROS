<?xml version="1.0"?>
<robot name="delta_robot">

  <material name="gris">
    <color rgba="0.55 0.55 0.55 0.5"/>
  </material>
  <material name="blanco">
    <color rgba="0.9 0.9 0.9 1"/>
  </material>
  <material name="colorte">
    <color rgba="0.15 0.55 0.95 0.8"/>
  </material>

  <!-- Base -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.005" radius="0.1055"/>
      </geometry>
      <material name="gris"/>
    </visual>
  </link>

  <!-- Upper arms -->
  <link name="brazo1">
    <visual>
      <origin xyz="0.100 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.200 0.01 0.01"/>
      </geometry>
      <material name="blanco"/>
    </visual>
  </link>
  <joint name="base_brazo1" type="revolute">
    <parent link="base_link"/>
    <child link="brazo1"/>
    <origin xyz="-0.0913656801 0.05275 0" rpy="0 0 2.61799"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" lower="0.0" upper="1.8" velocity="0.5"/>
  </joint>

  <link name="brazo2">
    <visual>
      <origin xyz="0.100 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.200 0.01 0.01"/>
      </geometry>
      <material name="blanco"/>
    </visual>
  </link>
  <joint name="base_brazo2" type="revolute">
    <parent link="base_link"/>
    <child link="brazo2"/>
    <origin xyz="0 -0.1055 0" rpy="0 0 -1.57075"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" lower="0.0" upper="1.8" velocity="0.5"/>
  </joint>

  <link name="brazo3">
    <visual>
      <origin xyz="0.100 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.200 0.01 0.01"/>
      </geometry>
      <material name="blanco"/>
    </visual>
  </link>
  <joint name="base_brazo3" type="revolute">
    <parent link="base_link"/>
    <child link="brazo3"/>
    <origin xyz="0.0913656801 0.05275 0" rpy="0 0 0.523599"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" lower="0.0" upper="1.8" velocity="0.5"/>
  </joint>

  <!-- Lower arms -->
  <link name="barra1_a"/>
  <joint name="codo1_a" type="revolute">
    <parent link="brazo1"/>
    <child link="barra1_a"/>
    <origin xyz="0.200 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit effort="100.0" lower="-3.14" upper="3.14" velocity="0.5"/>
  </joint>

  <link name="barra1_b">
    <visual>
      <origin xyz="-0.233 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.465 0.003 0.003"/>
      </geometry>
      <material name="blanco"/>
    </visual>
  </link>
  <joint name="codo1_b" type="revolute">
    <parent link="barra1_a"/>
    <child link="barra1_b"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100.0" lower="-3.14" upper="3.14" velocity="0.5"/>
  </joint>

  <link name="barra2_a"/>
  <joint name="codo2_a" type="revolute">
    <parent link="brazo2"/>
    <child link="barra2_a"/>
    <origin xyz="0.200 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit effort="100.0" lower="-3.14" upper="3.14" velocity="0.5"/>
  </joint>

  <link name="barra2_b">
    <visual>
      <origin xyz="-0.233 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.465 0.003 0.003"/>
      </geometry>
      <material name="blanco"/>
    </visual>
  </link>
  <joint name="codo2_b" type="revolute">
    <parent link="barra2_a"/>
    <child link="barra2_b"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100.0" lower="-3.14" upper="3.14" velocity="0.5"/>
  </joint>

  <link name="barra3_a"/>
  <joint name="codo3_a" type="revolute">
    <parent link="brazo3"/>
    <child link="barra3_a"/>
    <origin xyz="0.200 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit effort="100.0" lower="-3.14" upper="3.14" velocity="0.5"/>
  </joint>

  <link name="barra3_b">
    <visual>
      <origin xyz="-0.233 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.465 0.003 0.003"/>
      </geometry>
      <material name="blanco"/>
    </visual>
  </link>
  <joint name="codo3_b" type="revolute">
    <parent link="barra3_a"/>
    <child link="barra3_b"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100.0" lower="-3.14" upper="3.14" velocity="0.5"/>
  </joint>

  <!-- End-effector: orthogonal XYZ prismatic chain (TCP = act_x, act_y, act_z in base_link) -->
  <link name="aux1"/>
  <link name="aux2"/>
  <link name="actuador">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.002" radius="0.03"/>
      </geometry>
      <material name="colorte"/>
    </visual>
  </link>
  <link name="grip"/>

  <joint name="act_x" type="prismatic">
    <parent link="base_link"/>
    <child link="aux1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="100.0" lower="-0.6" upper="0.6" velocity="0.5"/>
  </joint>

  <joint name="act_y" type="prismatic">
    <parent link="aux1"/>
    <child link="aux2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" lower="-0.6" upper="0.6" velocity="0.5"/>
  </joint>

  <joint name="act_z" type="prismatic">
    <parent link="aux2"/>
    <child link="actuador"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100.0" lower="-0.6" upper="0.2" velocity="0.5"/>
  </joint>

  <joint name="gripper" type="fixed">
    <parent link="actuador"/>
    <child link="grip"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>
